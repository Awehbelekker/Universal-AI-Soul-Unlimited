# Copy to .env in the repo root (never commit .env).

# Optional Ollama default for the PWA proxy
# OLLAMA_URL=http://127.0.0.1:11434

# Google OAuth (Web application client)
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client → Application type: Web application
# 3. Authorized redirect URIs (add every URL you use to open the PWA):
#    http://127.0.0.1:8765/api/google/callback
#    http://localhost:8765/api/google/callback
#    http://YOUR-LAN-IP:8765/api/google/callback
# 4. Enable Gmail API: https://console.cloud.google.com/apis/library/gmail.googleapis.com
# 5. OAuth consent screen: External (or Internal for Workspace), add your Google account as test user while in Testing
# Optional: Google Custom Search (otherwise DuckDuckGo is used)
# https://programmablesearchengine.google.com/ + Google Cloud API key with Custom Search API
GOOGLE_CSE_ID=
GOOGLE_API_KEY=
