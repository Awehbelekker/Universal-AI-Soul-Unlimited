<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp"
    android:background="#E00F1C1A">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/widget_face"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/widget_face_circle"
            android:contentDescription="@string/widget_face_desc" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="18dp">

            <ImageView
                android:id="@+id/widget_eye_left"
                android:layout_width="10dp"
                android:layout_height="14dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/widget_eye"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/widget_eye_right"
                android:layout_width="10dp"
                android:layout_height="14dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/widget_eye"
                android:contentDescription="@null" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/widget_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#E8F2EF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_status_idle"
        android:textColor="#9EC4FF"
        android:textSize="11sp" />
</LinearLayout>
